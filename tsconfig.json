{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "types": ["bun"],
        "paths": {
            "src/*": ["./src/*"],
            "@go-hare/builtin-tools/*": ["./packages/builtin-tools/src/*"],
            "@go-hare/builtin-tools": ["./packages/builtin-tools/src/index.ts"],
            "@go-hare/mcp-client/*": ["./packages/mcp-client/src/*"],
            "@go-hare/mcp-client": ["./packages/mcp-client/src/index.ts"],
            "@go-hare/agent-tools/*": ["./packages/agent-tools/src/*"],
            "@go-hare/agent-tools": ["./packages/agent-tools/src/index.ts"],
            "@go-hare/weixin/*": ["./packages/weixin/src/*"],
            "@go-hare/weixin": ["./packages/weixin/src/index.ts"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "packages/**/*.ts", "packages/**/*.tsx"],
    "exclude": [
        "node_modules",
        "**/node_modules",
        "dist",
        "**/dist"
    ]
  }
